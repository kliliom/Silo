{"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"A ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource","type":"reference"},{"text":" can observe one or more upstream ","type":"text"},{"code":"AsyncStream","type":"codeVoice"},{"text":" values called ","type":"text"},{"inlineContent":[{"text":"dependencies","type":"text"}],"type":"emphasis"},{"text":". When a dependency emits a new value, the data source re-fetches — passing the latest dependency values directly into the fetch closure.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This is the idiomatic way to model data that derives from other changing state:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ An upstream stream of the currently selected user ID","let selectedUserID: AsyncStream<Int>","","\/\/ Automatically re-fetches whenever the selected user changes","let postsSource = dataSource(selectedUserID.dependency(.eager)) { userID in","    try await api.fetchPosts(forUser: userID)","} onError: { _ in .keep }",".build()"],"type":"codeListing"},{"inlineContent":[{"text":"Without dependencies, you’d have to observe ","type":"text"},{"code":"selectedUserID","type":"codeVoice"},{"text":" yourself, cancel any in-flight request, and manually call ","type":"text"},{"code":"refresh()","type":"codeVoice"},{"text":". Silo handles all of that.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Declaring-a-Dependency","text":"Declaring a Dependency","type":"heading"},{"inlineContent":[{"text":"Call ","type":"text"},{"code":".dependency(_:)","type":"codeVoice"},{"text":" on any ","type":"text"},{"code":"AsyncStream","type":"codeVoice"},{"text":" to create a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSourceDependency","type":"reference"},{"text":", then pass it as the first argument to ","type":"text"},{"code":"dataSource()","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let filterStream: AsyncStream<SortOrder>","","let productsSource = dataSource(filterStream.dependency(.lazy)) { sortOrder in","    try await api.fetchProducts(sortedBy: sortOrder)","} onError: { _ in .keep }",".build()"],"type":"codeListing"},{"inlineContent":[{"text":"The dependency value becomes a parameter to the fetch closure. Silo ensures the closure always receives the latest emitted value.","type":"text"}],"type":"paragraph"},{"name":"Important","style":"important","content":[{"inlineContent":[{"text":"The data source will not perform its first fetch until ","type":"text"},{"inlineContent":[{"type":"text","text":"all"}],"type":"emphasis"},{"text":" dependencies have emitted at least one value. If you have two dependencies and one emits before the other, the fetch is held until both have values.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"level":2,"anchor":"Refresh-Policies","text":"Refresh Policies","type":"heading"},{"inlineContent":[{"text":"The policy controls ","type":"text"},{"inlineContent":[{"text":"when","type":"text"}],"type":"emphasis"},{"text":" a refresh is triggered in response to a dependency change:","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"eager-Refresh-Immediately","text":"`.eager` — Refresh Immediately","type":"heading"},{"syntax":"swift","code":["selectedUserID.dependency(.eager)"],"type":"codeListing"},{"inlineContent":[{"text":"Refresh happens immediately when the dependency emits, regardless of whether there are active subscribers. Use ","type":"text"},{"code":".eager","type":"codeVoice"},{"text":" when you want data pre-warmed and ready before any view subscribes — for example, when you anticipate the user navigating to a screen.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"lazy-Refresh-Only-When-Observed","text":"`.lazy` — Refresh Only When Observed","type":"heading"},{"syntax":"swift","code":["selectedUserID.dependency(.lazy)"],"type":"codeListing"},{"inlineContent":[{"text":"If the dependency emits while there are no subscribers, the refresh is deferred. When the first subscriber arrives, the deferred refresh fires immediately, delivering fresh data right away.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Use ","type":"text"},{"code":".lazy","type":"codeVoice"},{"text":" for data that is only relevant when its corresponding UI is visible. This avoids network calls for screens the user hasn’t navigated to yet.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"manual-Manual-Control","text":"`.manual` — Manual Control","type":"heading"},{"syntax":"swift","code":["selectedUserID.dependency(.manual)"],"type":"codeListing"},{"inlineContent":[{"text":"Dependency changes do not trigger automatic refreshes. The dependency value is still available in the fetch closure — you just control when ","type":"text"},{"code":"refresh()","type":"codeVoice"},{"text":" is called yourself.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Use ","type":"text"},{"code":".manual","type":"codeVoice"},{"text":" when you want the fetch closure to ","type":"text"},{"inlineContent":[{"type":"text","text":"use"}],"type":"emphasis"},{"type":"text","text":" the upstream value but need external logic to decide the right time to refresh (for example, after a confirmation dialog)."}],"type":"paragraph"},{"anchor":"Policy-Comparison","level":3,"text":"Policy Comparison","type":"heading"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Policy"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Refresh timing","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Best for","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":".eager","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"Immediately on change","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"Pre-warming; always-fresh data"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".lazy","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"When first subscriber arrives","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"On-demand screens; avoid unnecessary work"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"code":".manual","type":"codeVoice"}]}],[{"inlineContent":[{"text":"Never automatically","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Manual control; gated refresh"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"anchor":"Clearing-on-Dependency-Change","level":2,"text":"Clearing on Dependency Change","type":"heading"},{"inlineContent":[{"text":"Pass ","type":"text"},{"code":"clear: true","type":"codeVoice"},{"text":" to emit the empty value immediately when the dependency changes — before the new fetch completes:","type":"text"}],"type":"paragraph"},{"code":["selectedUserID.dependency(.eager, clear: true)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Without "},{"type":"codeVoice","code":"clear: true"},{"type":"text","text":", the previous user’s posts remain visible while the new user’s posts are being fetched. With "},{"type":"codeVoice","code":"clear: true"},{"type":"text","text":", the list clears immediately on switch, showing a loading state until the new data arrives."}],"type":"paragraph"},{"type":"table","rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[{"text":"Without ","type":"text"},{"code":"clear: true","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"With ","type":"text"},{"type":"codeVoice","code":"clear: true"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"On change","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Previous data shown during fetch","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Empty value shown during fetch","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Best for","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Smooth transitions (similar data)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Hard context switches (unrelated data)","type":"text"}],"type":"paragraph"}]]],"header":"row"},{"level":2,"type":"heading","text":"Multiple Dependencies","anchor":"Multiple-Dependencies"},{"type":"paragraph","inlineContent":[{"text":"Pass multiple dependencies to observe several upstream streams simultaneously. The fetch closure receives all values as parameters:","type":"text"}]},{"syntax":"swift","code":["let userID:   AsyncStream<Int>","let category: AsyncStream<Category>","let sortOrder: AsyncStream<SortOrder>","","let feedSource = dataSource(","    userID.dependency(.lazy),","    category.dependency(.lazy, clear: true),","    sortOrder.dependency(.lazy)",") { userID, category, sortOrder in","    try await api.fetchFeed(","        for: userID,","        in: category,","        sorted: sortOrder","    )","} onError: { _ in .keep }",".build()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The data source refreshes whenever "},{"type":"emphasis","inlineContent":[{"type":"text","text":"any"}]},{"type":"text","text":" dependency emits a new value, using the latest value of all others. The first fetch waits until every dependency has emitted at least once."}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"Dependencies are implemented using Swift’s variadic generics (","type":"text"},{"code":"repeat each","type":"codeVoice"},{"text":"), so the type of each dependency value is fully preserved and compiler-checked.","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"},{"type":"heading","text":"Pre-fetch Hooks","level":2,"anchor":"Pre-fetch-Hooks"},{"inlineContent":[{"text":"Reactive dependencies let an upstream stream ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"push","type":"text"}]},{"text":" changes to a data source. Pre-fetch hooks are the complementary pattern: the data source ","type":"text"},{"inlineContent":[{"text":"pulls","type":"text"}],"type":"emphasis"},{"text":" from upstream immediately before each fetch.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The primary use case is ensuring a related data source is fresh before your fetch runs:"}]},{"syntax":"swift","type":"codeListing","code":["let profileSource = dataSource {","    try await api.fetchProfile(token: authSource.value!)","} onError: { _ in .keep }",".beforeFetch(refresh: authSource)  \/\/ Refresh auth token first",".build()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every time "},{"type":"codeVoice","code":"profileSource.refresh()"},{"type":"text","text":" is called, "},{"type":"codeVoice","code":"authSource.refresh()"},{"type":"text","text":" completes first. Because "},{"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/refresh(clear:)","type":"reference","isActive":true},{"type":"text","text":" deduplicates in-flight requests, if "},{"type":"codeVoice","code":"authSource"},{"type":"text","text":" is already refreshing the call simply joins that task — no redundant network request."}]},{"type":"heading","anchor":"General-closure-form","text":"General closure form","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"For preparation work that isn’t a "},{"type":"codeVoice","code":"DataSource"},{"text":" refresh, pass a closure directly:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let source = dataSource { ... }","    .beforeFetch {","        try await analyticsService.logFetchStarted()","    }","    .build()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Multiple "},{"type":"codeVoice","code":".beforeFetch()"},{"type":"text","text":" calls run concurrently before the fetch. If any hook throws, the remaining hooks are cancelled:"}]},{"type":"codeListing","syntax":"swift","code":["dataSource { ... }","    .beforeFetch(refresh: authSource)","    .beforeFetch(refresh: configSource)","    .build()"]},{"text":"Failable hooks","type":"heading","anchor":"Failable-hooks","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the pre-fetch work is best-effort — a failure shouldn’t block the main fetch — use "},{"type":"codeVoice","code":".failableBeforeFetch()"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["dataSource { ... }","    .failableBeforeFetch { try await prefetchCache.warm() }","    .build()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Any error thrown by a failable hook is silently discarded and the fetch proceeds normally."}]},{"text":"Error handling","type":"heading","anchor":"Error-handling","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"When a "},{"type":"codeVoice","code":".beforeFetch()"},{"type":"text","text":" hook throws, the error is wrapped in a "},{"identifier":"doc:\/\/Silo\/documentation\/Silo\/BeforeFetchError","type":"reference","isActive":true},{"type":"text","text":" before being passed to the "},{"type":"codeVoice","code":"onError"},{"type":"text","text":" handler. This lets you distinguish a pre-fetch failure from a fetch failure:"}]},{"type":"codeListing","syntax":"swift","code":["dataSource {","    try await api.fetchProfile(token: authSource.value!)","} onError: { error in","    if let beforeFetchError = error as? BeforeFetchError {","        \/\/ Auth token refresh failed — keep stale profile","        return .keep","    }","    \/\/ Fetch itself failed — clear stale data","    return .clear","}",".beforeFetch(refresh: authSource)",".build()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The hook runs after all gate checks (TTL, throttle, debounce, prerequisites) and only once per actual fetch task — concurrent "},{"type":"codeVoice","code":"refresh()"},{"type":"text","text":" callers that join an in-flight task do not re-run it."}]},{"text":"Pre-fetch hooks vs reactive dependencies","type":"heading","anchor":"Pre-fetch-hooks-vs-reactive-dependencies","level":3},{"header":"row","type":"table","rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"Reactive dependency","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pre-fetch hook"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Direction"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Upstream pushes → source reacts"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Source pulls from upstream before fetching"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Trigger"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Upstream emits a new value"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Every "},{"code":"refresh()","type":"codeVoice"},{"text":" that proceeds past the gates","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"Use when"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The upstream value is an "},{"inlineContent":[{"text":"input","type":"text"}],"type":"emphasis"},{"type":"text","text":" to the fetch"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Another source must be fresh "},{"inlineContent":[{"text":"before","type":"text"}],"type":"emphasis"},{"type":"text","text":" you fetch"}],"type":"paragraph"}]]]},{"anchor":"Combining-Dependencies-with-Time-Controls","text":"Combining Dependencies with Time Controls","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Dependencies work naturally with debounce and throttle. A typical search pattern:","type":"text"}]},{"type":"codeListing","code":["let searchQuery: AsyncStream<String>","","let resultsSource = dataSource(searchQuery.dependency(.lazy)) { query in","    guard !query.isEmpty else { return [] }","    return try await api.search(query: query)","} onError: { _ in .keep }",".debounce(.milliseconds(300))  \/\/ Wait for the user to pause typing",".build()"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When "},{"type":"codeVoice","code":"searchQuery"},{"type":"text","text":" emits, Silo triggers a refresh, but the debounce delays execution until 300ms of silence — preventing a fetch on every keystroke."}]},{"text":"The Dependency Lifecycle","type":"heading","anchor":"The-Dependency-Lifecycle","level":2},{"type":"codeListing","syntax":null,"code":["Dependency emits value","    │","    ├─ .manual ────────────────────── No refresh triggered","    │","    ├─ .eager ─────────────────────── refresh() called immediately","    │                                 (regardless of subscriber count)","    │","    └─ .lazy ─── Has subscribers? ─── Yes ──► refresh() called immediately","                        │","                        No ──────────────────► Flag pending refresh","                                               │","                                         First subscriber arrives","                                               │","                                         refresh() called"]},{"text":"When Not to Use Dependencies","type":"heading","anchor":"When-Not-to-Use-Dependencies","level":2},{"type":"paragraph","inlineContent":[{"text":"Use dependencies when the upstream value is the ","type":"text"},{"inlineContent":[{"type":"text","text":"input"}],"type":"emphasis"},{"text":" to a fetch — e.g., the selected user ID determines which user’s data to load.","type":"text"}]},{"inlineContent":[{"text":"Don’t use dependencies as a mechanism to trigger a refresh when ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"some other thing happens"}]},{"type":"text","text":" — for that, just call "},{"type":"codeVoice","code":"refresh()"},{"type":"text","text":" or "},{"type":"codeVoice","code":"restartAutoRefresh()"},{"type":"text","text":" directly."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ ✗ Don't: create a fake stream just to trigger refresh","let triggerStream = AsyncStream<Void> { ... }","let source = dataSource(triggerStream.dependency(.eager)) { _ in","    try await api.fetchData()","} onError: { _ in .keep }",".build()","","\/\/ ✓ Do: just call refresh() when the triggering condition occurs","let source = dataSource {","    try await api.fetchData()","} onError: { _ in .keep }",".build()","","\/\/ Later, when the condition occurs:","await source.refresh()"]}]}],"hierarchy":{"paths":[["doc:\/\/Silo\/documentation\/Silo"]]},"abstract":[{"text":"Automatically re-fetch data whenever upstream async stream values change.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"article","metadata":{"title":"Dependencies and Reactive Fetching","roleHeading":"Article","modules":[{"name":"Silo"}],"role":"article"},"variants":[{"paths":["\/documentation\/silo\/dependencies"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"url":"doc:\/\/Silo\/documentation\/Silo\/Dependencies","interfaceLanguage":"swift"},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/Silo\/documentation\/Silo\/TimeControls","doc:\/\/Silo\/documentation\/Silo\/RefreshPolicy","doc:\/\/Silo\/documentation\/Silo\/DataSourceDependency","doc:\/\/Silo\/documentation\/Silo\/BeforeFetchError","doc:\/\/Silo\/tutorials\/Silo\/ReactiveDependencies"],"anchor":"Related-Documentation"},{"generated":true,"title":"Guides","identifiers":["doc:\/\/Silo\/documentation\/Silo\/Caching","doc:\/\/Silo\/documentation\/Silo\/ErrorHandling","doc:\/\/Silo\/documentation\/Silo\/TimeControls","doc:\/\/Silo\/documentation\/Silo\/Prerequisites"],"anchor":"Guides"}],"references":{"doc://Silo/documentation/Silo/TimeControls":{"type":"topic","abstract":[{"type":"text","text":"Limit fetch frequency with throttling, smooth out bursts with debouncing, and keep data current with auto-refresh."}],"role":"article","kind":"article","url":"\/documentation\/silo\/timecontrols","identifier":"doc:\/\/Silo\/documentation\/Silo\/TimeControls","title":"Time Controls"},"doc://Silo/tutorials/Silo/ReactiveDependencies":{"type":"topic","abstract":[{"text":"Build a configurable dice roller that automatically re-rolls whenever the player changes the dice type or count. You will learn how to declare dependencies, choose the right refresh policy, and wire SwiftUI pickers to reactive streams — resulting in a fully functional application.","type":"text"}],"role":"project","kind":"project","estimatedTime":"30min","url":"\/tutorials\/silo\/reactivedependencies","identifier":"doc:\/\/Silo\/tutorials\/Silo\/ReactiveDependencies","title":"Reacting to Dice Configuration"},"doc://Silo/documentation/Silo/Prerequisites":{"type":"topic","abstract":[{"type":"text","text":"Gate fetches on runtime conditions such as network availability or user authentication state."}],"role":"article","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/Prerequisites","title":"Prerequisites and Conditional Fetching","url":"\/documentation\/silo\/prerequisites"},"doc://Silo/documentation/Silo/Caching":{"url":"\/documentation\/silo\/caching","type":"topic","abstract":[{"type":"text","text":"Prevent redundant network calls by keeping fetched data valid for a configurable duration."}],"title":"Caching with TTL","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/Caching","role":"article"},"doc://Silo/documentation/Silo/RefreshPolicy":{"type":"topic","abstract":[{"text":"Controls when a ","type":"text"},{"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource","isActive":true,"type":"reference"},{"text":" refreshes in response to a dependency change.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"RefreshPolicy"}],"navigatorTitle":[{"kind":"identifier","text":"RefreshPolicy"}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/RefreshPolicy","title":"RefreshPolicy","url":"\/documentation\/silo\/refreshpolicy"},"doc://Silo/documentation/Silo/DataSourceBuilder/beforeFetch(_:)":{"url":"\/documentation\/silo\/datasourcebuilder\/beforefetch(_:)","type":"topic","abstract":[{"type":"text","text":"Register an async closure to run before each fetch."}],"title":"beforeFetch(_:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"beforeFetch"},{"text":"(() ","kind":"text"},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"text":" -> ","kind":"text"},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSourceBuilder\/beforeFetch(_:)","role":"symbol"},"doc://Silo/documentation/Silo/DataSourceDependency":{"type":"topic","abstract":[{"text":"An ","type":"text"},{"type":"codeVoice","code":"AsyncStream"},{"text":" paired with a ","type":"text"},{"identifier":"doc:\/\/Silo\/documentation\/Silo\/RefreshPolicy","type":"reference","isActive":true},{"text":" and clear flag, for use as a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource","type":"reference"},{"type":"text","text":" dependency."}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DataSourceDependency","kind":"identifier"}],"navigatorTitle":[{"text":"DataSourceDependency","kind":"identifier"}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSourceDependency","title":"DataSourceDependency","url":"\/documentation\/silo\/datasourcedependency"},"doc://Silo/documentation/Silo/DataSource/refresh(clear:)":{"url":"\/documentation\/silo\/datasource\/refresh(clear:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"refresh"},{"kind":"text","text":"("},{"kind":"externalParam","text":"clear"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Value"}],"title":"refresh(clear:)","abstract":[{"type":"text","text":"Fetches new data, updating the cache and notifying all stream subscribers on success."}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/refresh(clear:)","type":"topic","role":"symbol"},"doc://Silo/documentation/Silo":{"type":"topic","abstract":[{"type":"text","text":"Reactive async data management for Swift 6 — fetch, cache, and stream data with zero dependencies."}],"role":"collection","kind":"symbol","identifier":"doc:\/\/Silo\/documentation\/Silo","title":"Silo","url":"\/documentation\/silo"},"doc://Silo/documentation/Silo/BeforeFetchError":{"type":"topic","abstract":[{"text":"The error thrown when a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSourceBuilder\/beforeFetch(_:)","type":"reference"},{"text":" hook fails.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"BeforeFetchError"}],"navigatorTitle":[{"kind":"identifier","text":"BeforeFetchError"}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/BeforeFetchError","title":"BeforeFetchError","url":"\/documentation\/silo\/beforefetcherror"},"doc://Silo/documentation/Silo/DataSource":{"url":"\/documentation\/silo\/datasource","type":"topic","abstract":[{"text":"Manages asynchronous data fetching, caching, and reactive streaming for a single value type.","type":"text"}],"title":"DataSource","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"DataSource"}],"navigatorTitle":[{"text":"DataSource","kind":"identifier"}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource","role":"symbol"},"doc://Silo/documentation/Silo/ErrorHandling":{"type":"topic","abstract":[{"text":"Decide what happens to cached data on failure, and configure automatic retry with backoff strategies.","type":"text"}],"role":"article","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/ErrorHandling","title":"Error Handling and Retry","url":"\/documentation\/silo\/errorhandling"}}}