ltiple "},{"type":"codeVoice","code":".beforeFetch()"},{"type":"text","text":" calls execute concurrently. If any hook throws, the"},{"type":"text","text":" "},{"type":"text","text":"remaining hooks are cancelled and the fetch is aborted."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Example:"}],"type":"paragraph"},{"code":["dataSource {","    try await api.fetchProfile()","} onError: { error in","    if error is BeforeFetchError { return .keep }","    return .clear","}",".beforeFetch { try await authSource.refresh() }",".build()"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/Silo\/documentation\/Silo","doc:\/\/Silo\/documentation\/Silo\/DataSourceBuilder"]]},"abstract":[{"text":"Register an async closure to run before each fetch.","type":"text"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","metadata":{"roleHeading":"Instance Method","symbolKind":"method","externalID":"s:4Silo17DataSourceBuilderC11beforeFetchyACyxGXDyyYaYbKcF","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"beforeFetch"},{"kind":"text","text":"(() "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"}],"title":"beforeFetch(_:)","modules":[{"name":"Silo"}],"role":"symbol"},"variants":[{"paths":["\/documentation\/silo\/datasourcebuilder\/beforefetch(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"url":"doc:\/\/Silo\/documentation\/Silo\/DataSourceBuilder\/beforeFetch(_:)","interfaceLanguage":"swift"},"references":{"doc://Silo/documentation/Silo":{"type":"topic","abstract":[{"type":"text","text":"Reactive async data management for Swift 6 — fetch, cache, and stream data with zero dependencies."}],"role":"collection","kind":"