{"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"inlineContent":[{"text":"A ","type":"text"},{"inlineContent":[{"text":"prerequisite","type":"text"}],"type":"emphasis"},{"text":" is an async check that must pass before a fetch is allowed to proceed. If any prerequisite returns ","type":"text"},{"code":"false","type":"codeVoice"},{"text":", the fetch is cancelled with a ","type":"text"},{"identifier":"doc:\/\/Silo\/documentation\/Silo\/PrerequisiteError","isActive":true,"type":"reference"},{"text":" instead of hitting the network.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Prerequisites are the right tool when a fetch shouldn’t even be attempted under certain conditions — not when you want to change the ","type":"text"},{"inlineContent":[{"text":"result","type":"text"}],"type":"emphasis"},{"text":" of a failed fetch (use ","type":"text"},{"code":"onError","type":"codeVoice"},{"text":" for that).","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[{"text":"Prerequisites","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"onError","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"inlineContent":[{"text":"Purpose","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Prevent fetches that would certainly fail","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"React to fetches that did fail","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"inlineContent":[{"text":"When evaluated","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Before every fetch attempt","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"After a fetch throws","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"inlineContent":[{"text":"If check fails","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Throws ","type":"text"},{"code":"PrerequisiteError","type":"codeVoice"},{"text":"; no network call","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Decides cache state; re-throws the error","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"inlineContent":[{"text":"Common uses","type":"text"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Network offline, not logged in","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Transient errors, auth expiry, rate limits","type":"text"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"anchor":"Defining-a-Prerequisite","type":"heading","level":2,"text":"Defining a Prerequisite"},{"inlineContent":[{"text":"Conform any ","type":"text"},{"code":"Sendable","type":"codeVoice"},{"text":" type to ","type":"text"},{"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSourceRefreshPrerequisite","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["struct NetworkAvailable: DataSourceRefreshPrerequisite {","    func check() async -> Bool {","        await NetworkMonitor.shared.isConnected","    }","}"],"syntax":"swift"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"check()","type":"codeVoice"},{"text":" method is ","type":"text"},{"code":"async","type":"codeVoice"},{"text":", so you can perform any awaitable check — including one that itself involves a network or system call.","type":"text"}],"type":"paragraph"},{"anchor":"Adding-Prerequisites-to-a-Data-Source","type":"heading","level":2,"text":"Adding Prerequisites to a Data Source"},{"inlineContent":[{"text":"Chain ","type":"text"},{"code":".requires(_:)","type":"codeVoice"},{"text":" on the builder before ","type":"text"},{"code":".build()","type":"codeVoice"},{"text":". Multiple prerequisites are evaluated in order; the first failure stops the check and throws:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let profileSource = dataSource {","    try await api.fetchProfile()","} onError: { _ in .keep }",".requires(NetworkAvailable())",".requires(UserAuthenticated())",".build()"],"type":"codeListing"},{"level":2,"anchor":"Handling-Prerequisite-Failures","text":"Handling Prerequisite Failures","type":"heading"},{"inlineContent":[{"text":"When a prerequisite fails, ","type":"text"},{"code":"refresh()","type":"codeVoice"},{"text":" throws a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/PrerequisiteError","type":"reference"},{"text":". Catch it to distinguish prerequisite failures from network failures:","type":"text"}],"type":"paragraph"},{"code":["do {","    try await profileSource.refresh()","} catch let error as PrerequisiteError {","    \/\/ Condition not met — show an appropriate message","    showOfflineBanner(error.message)","} catch {","    \/\/ Actual fetch error","    showErrorAlert(error)","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Common-Prerequisite-Implementations","text":"Common Prerequisite Implementations","level":2,"type":"heading"},{"anchor":"Network-Reachability","text":"Network Reachability","level":3,"type":"heading"},{"code":["import Network","","actor NetworkMonitor {","    static let shared = NetworkMonitor()","","    private let monitor = NWPathMonitor()","    private var isConnected = false","","    init() {","        monitor.pathUpdateHandler = { [weak self] path in","            Task { await self?.update(path.status == .satisfied) }","        }","        monitor.start(queue: .global(qos: .background))","    }","","    private func update(_ connected: Bool) { isConnected = connected }","    func checkConnected() async -> Bool { isConnected }","}","","struct NetworkAvailable: DataSourceRefreshPrerequisite {","    func check() async -> Bool {","        await NetworkMonitor.shared.checkConnected()","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"User-Authentication","text":"User Authentication","level":3,"type":"heading"},{"code":["struct UserAuthenticated: DataSourceRefreshPrerequisite {","    func check() async -> Bool {","        await AuthStore.shared.isLoggedIn","    }","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Feature-Flag","level":3,"text":"Feature Flag","type":"heading"},{"code":["struct FeatureEnabled: DataSourceRefreshPrerequisite {","    let flagName: String","","    func check() async -> Bool {","        await FeatureFlags.shared.isEnabled(flagName)","    }","}","","\/\/ Usage:","dataSource { ... }","    .requires(FeatureEnabled(flagName: \"newFeedAlgorithm\"))","    .build()"],"syntax":"swift","type":"codeListing"},{"anchor":"Combined-Example","level":3,"text":"Combined Example","type":"heading"},{"code":["let secureDataSource = dataSource {","    try await api.fetchSecureData()","} onError: { error in","    error is AuthError ? .clear : .keep","}",".requires(NetworkAvailable())",".requires(UserAuthenticated())",".requires(FeatureEnabled(flagName: \"secureFeature\"))",".retry(count: 2, delay: .seconds(1)) { error in","    error is URLError ? .retry : .keep","}",".ttl(.seconds(300))",".build()"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"In this configuration:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Network is checked first — no request attempted if offline","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Auth is verified second — no request if logged out"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Feature flag is checked third — no request if feature is off"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"If all pass and the fetch fails, retry up to 2 times","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Cache results for 5 minutes","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"anchor":"Prerequisite-Evaluation-Order","level":2,"text":"Prerequisite Evaluation Order","type":"heading"},{"inlineContent":[{"type":"text","text":"Prerequisites are evaluated sequentially in the order they were added. Evaluation stops at the first failure — subsequent prerequisites are not checked."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":[".requires(NetworkAvailable())   \/\/ Checked first",".requires(UserAuthenticated())  \/\/ Only checked if network is available",".requires(FeatureEnabled(...))  \/\/ Only checked if both above pass"]},{"anchor":"Prerequisites-and-Retry","text":"Prerequisites and Retry","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Prerequisite checks happen "},{"type":"emphasis","inlineContent":[{"type":"text","text":"before"}]},{"type":"text","text":" the retry loop. If a prerequisite fails, the fetch is not attempted — and the retry strategy never kicks in. This is intentional: retrying a fetch when the prerequisite is already known to be unmet would be wasteful."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you need to retry until a prerequisite passes (for example, waiting for a network connection to be restored), handle that at a higher level — poll or observe the prerequisite’s underlying state and call "},{"type":"codeVoice","code":"refresh()"},{"type":"text","text":" when it changes."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/Silo\/documentation\/Silo"]]},"abstract":[{"type":"text","text":"Gate fetches on runtime conditions such as network availability or user authentication state."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"article","metadata":{"role":"article","roleHeading":"Article","title":"Prerequisites and Conditional Fetching","modules":[{"name":"Silo"}]},"variants":[{"paths":["\/documentation\/silo\/prerequisites"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"url":"doc:\/\/Silo\/documentation\/Silo\/Prerequisites","interfaceLanguage":"swift"},"se