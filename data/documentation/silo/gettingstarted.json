{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"text":"Silo revolves around ","type":"text"},{"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource","isActive":true,"type":"reference"},{"text":", a ","type":"text"},{"code":"@MainActor","type":"codeVoice"},{"text":" class that wraps an async fetch closure, maintains a cached value, and streams updates to all active subscribers. You create one with the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSourceBuilder","type":"reference"},{"text":" returned by the ","type":"text"},{"code":"dataSource()","type":"codeVoice"},{"text":" function family, chain configuration methods, then call ","type":"text"},{"code":".build()","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"code":["@MainActor","let articlesSource = dataSource {","    try await api.fetchArticles()","} onError: { _ in .keep }",".ttl(.seconds(300))",".autoRefresh(.seconds(60))",".build()"],"syntax":"swift","type":"codeListing"},{"anchor":"Adding-Silo","text":"Adding Silo","level":2,"type":"heading"},{"inlineContent":[{"text":"In your ","type":"text"},{"code":"Package.swift","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["dependencies: [","    .package(url: \"https:\/\/github.com\/kliliom\/silo\", from: \"1.0.0\")","],","targets: [","    .target(name: \"MyApp\", dependencies: [\"Silo\"])","]"],"syntax":"swift","type":"codeListing"},{"anchor":"Choosing-a-Builder-Overload","text":"Choosing a Builder Overload","level":2,"type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"dataSource()","type":"codeVoice"},{"text":" function has overloads that eliminate boilerplate for common value types:","type":"text"}],"type":"paragraph"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Value type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Overload to use"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Empty state"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"User?"},{"type":"text","text":", "},{"type":"codeVoice","code":"String?"},{"type":"text","text":", any "},{"type":"codeVoice","code":"Optional"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"dataSource { ... } onError: { ... }"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"nil"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"[User]"},{"type":"text","text":", "},{"type":"codeVoice","code":"[String]"},{"type":"text","text":", any "},{"type":"codeVoice","code":"Array"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"dataSource { ... } onError: { ... }"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"[]"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"[String: Any]"},{"type":"text","text":", any "},{"type":"codeVoice","code":"Dictionary"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"dataSource { ... } onError: { ... }"}]}],[{"inlineContent":[{"type":"codeVoice","code":"[:]"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Any other type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"dataSource { ... } onError: { ... } emptyValue: { ... }"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Your placeholder"}]}]]],"type":"table"},{"inlineContent":[{"text":"For ","type":"text"},{"code":"Optional","type":"codeVoice"},{"text":", ","type":"text"},{"code":"Array","type":"codeVoice"},{"type":"text","text":", and "},{"type":"codeVoice","code":"Dictionary"},{"type":"text","text":" values the empty state is inferred automatically. For any other type you must supply an "},{"type":"codeVoice","code":"emptyValue"},{"type":"text","text":" closure that returns a placeholder:"}],"type":"paragraph"},{"code":["\/\/ Optional — empty state is nil automatically","let profileSource = dataSource {","    try await api.fetchProfile() \/\/ User?","} onError: { _ in .keep }",".build()","","\/\/ Array — empty state is [] automatically","let usersSource = dataSource {","    try await api.fetchUsers() \/\/ [User]","} onError: { _ in .keep }",".build()","","\/\/ Custom type — must provide emptyValue","let statsSource = dataSource {","    try await api.fetchStats() \/\/ AppStats (non-optional struct)","} onError: { _ in .keep }","emptyValue: {","    AppStats.zero","}",".build()"],"syntax":"swift","type":"codeListing"},{"name":"Important","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"dataSource()"},{"type":"text","text":" and all "},{"code":"DataSource","type":"codeVoice"},{"type":"text","text":" methods must be called on the "},{"code":"@MainActor","type":"codeVoice"},{"text":". Mark your containing type ","type":"text"},{"code":"@MainActor","type":"codeVoice"},{"type":"text","text":", or call from within a "},{"code":"@MainActor","type":"codeVoice"},{"type":"text","text":" context such as a "},{"code":"Task { @MainActor in ... }","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"style":"important","type":"aside"},{"anchor":"Understanding-the-Empty-Value","text":"Understanding the Empty Value","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The empty value is what a "},{"type":"codeVoice","code":"DataSource"},{"text":" holds before its first successful fetch, and what it reverts to after ","type":"text"},{"code":"clear()","type":"codeVoice"},{"text":" is called or a TTL expiry clears it. It serves as the “zero state” for the type — a safe default that makes the source always usable without optionality at the call site.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Choose an empty value that is safe to display. A ","type":"text"},{"code":"User","type":"codeVoice"},{"text":" might have ","type":"text"},{"code":"name: \"\"","type":"codeVoice"},{"text":", a ","type":"text"},{"code":"[Product]","type":"codeVoice"},{"text":" is already ","type":"text"},{"code":"[]","type":"codeVoice"},{"text":", and a ","type":"text"},{"code":"Stats","type":"codeVoice"},{"text":" might have all counters at ","type":"text"},{"code":"0","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Triggering-a-Fetch","text":"Triggering a Fetch","level":2,"type":"heading"},{"inlineContent":[{"text":"Call ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/refresh(clear:)","type":"reference"},{"text":" to load data. It returns the fetched value and throws on failure:","type":"text"}],"type":"paragraph"},{"code":["do {","    let articles = try await articlesSource.refresh()","    print(\"Loaded \\(articles.count) articles\")","} catch {","    print(\"Failed: \\(error)\")","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"codeVoice","code":"refresh()"},{"text":" is idempotent with respect to in-flight requests: if one is already running when a second caller invokes ","type":"text"},{"code":"refresh()","type":"codeVoice"},{"text":", both callers await the same underlying task. No duplicate network calls are made.","type":"text"}],"type":"paragraph"},{"anchor":"Force-Refreshing-Past-the-Cache","level":3,"text":"Force-Refreshing Past the Cache","type":"heading"},{"inlineContent":[{"text":"Pass ","type":"text"},{"code":"clear: true","type":"codeVoice"},{"text":" to reset the cache and bypass any active TTL window:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Pull-to-refresh — ignore cache, always fetch fresh","let articles = try await articlesSource.refresh(clear: true)"],"syntax":"swift","type":"codeListing"},{"anchor":"Observing-Values","level":2,"text":"Observing Values","type":"heading"},{"inlineContent":[{"text":"Subscribe to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/values","type":"reference"},{"text":" to receive the current cached value immediately, then live updates whenever a ","type":"text"},{"code":"refresh()","type":"codeVoice"},{"text":" completes:","type":"text"}],"type":"paragraph"},{"code":["for await articles in articlesSource.values {","    tableView.reloadData(with: articles)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The first element delivered to a new subscriber is always the current cached value — this might be the empty value if no fetch has happened yet, or the last successfully fetched value otherwise. This makes stream subscriptions self-bootstrapping: no separate “initial load” call is required.","type":"text"}],"type":"paragraph"},{"style":"tip","content":[{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":".task { }"},{"type":"text","text":" in SwiftUI views to subscribe and automatically cancel when the view disappears."}],"type":"paragraph"}],"name":"Tip","type":"aside"},{"anchor":"Custom-Buffering","level":3,"text":"Custom Buffering","type":"heading"},{"inlineContent":[{"text":"The default stream buffers all values without limit. For fast-changing data, limit the buffer to avoid queuing stale values:","type":"text"}],"type":"paragraph"},{"code":["\/\/ Only keep the most recent update for a fast-changing source","for await price in stockSource.values(bufferingPolicy: .bufferingNewest(1)) {","    updatePriceLabel(price)","}"],"syntax":"swift","type":"codeListing"},{"anchor":"Tracking-Loading-and-Empty-State","level":2,"text":"Tracking Loading and Empty State","type":"heading"},{"inlineContent":[{"text":"Subscribe to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/state","type":"reference"},{"text":" to drive loading indicators and empty-state views:","type":"text"}],"type":"paragraph"},{"code":["for await state in articlesSource.state {","    loadingView.isHidden = !state.isRefreshing","    emptyView.isHidden = !state.isEmpty","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSourceState","type":"reference"},{"text":" has two boolean properties:","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Property"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"true"},{"type":"text","text":" when…"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"false"},{"type":"text","text":" when…"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"isRefreshing"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"A fetch is in progress"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"No fetch is running"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"isEmpty"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"The current value is the empty value"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Data has been successfully fetched"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"inlineContent":[{"text":"Possible state combinations:","type":"text"}],"type":"paragraph"},{"rows":[[[{"inlineContent":[{"type":"codeVoice","code":"isRefreshing"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"isEmpty"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Meaning"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"false"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"true"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Initial state — nothing fetched yet"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"true"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"false"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Refreshing while showing existing data"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"true"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"true"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"First fetch in progress (or refreshing after clear)"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"false"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"false"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Data loaded and idle"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"anchor":"Observing-Value-and-State-Together","level":2,"text":"Observing Value and State Together","type":"heading"},{"inlineContent":[{"text":"Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/valueWithState","type":"reference"},{"text":" to get a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSourceValueWithState","type":"reference"},{"text":" snapshot on every change — value or state. This is the most convenient stream for driving a SwiftUI view:","type":"text"}],"type":"paragraph"},{"code":["for await snapshot in articlesSource.valueWithState {","    loadingSpinner.isVisible = snapshot.state.isRefreshing","    updateList(snapshot.value)","}"],"syntax":"swift","type":"codeListing"},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"Subscribing to "},{"type":"codeVoice","code":"valueWithState"},{"type":"text","text":" counts toward the active subscriber count for auto-refresh purposes, just like "},{"type":"codeVoice","code":"values"},{"type":"text","text":" does."}],"type":"paragraph"}],"name":"Note","type":"aside"},{"anchor":"Clearing-Cached-Data","level":2,"text":"Clearing Cached Data","type":"heading"},{"inlineContent":[{"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/clear()","isActive":true,"type":"reference"},{"text":" resets the source to its empty state immediately:","type":"text"}],"type":"paragraph"},{"code":["func signOut() async {","    profileSource.clear()","    articlesSource.clear()","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Clearing:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Sets the cached value to the result of ","type":"text"},{"code":"emptyValue()","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Emits the empty value to all "},{"code":"values","type":"codeVoice"},{"type":"text","text":" subscribers"}]}]},{"content":[{"inlineContent":[{"text":"Sets ","type":"text"},{"code":"isEmpty","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"true","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Cancels active TTL, throttle, and debounce timers","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Does ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" cancel an in-flight fetch task"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","anchor":"Cancelling-In-Flight-Fetches","text":"Cancelling In-Flight Fetches","level":2},{"inlineContent":[{"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/cancelRefresh(clear:)","type":"reference","isActive":true},{"type":"text","text":" cancels any running fetch task:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Cancel without clearing cache","articlesSource.cancelRefresh()","","\/\/ Cancel and wipe the cache","articlesSource.cancelRefresh(clear: true)"]},{"inlineContent":[{"type":"text","text":"Any "},{"type":"codeVoice","code":"refresh()"},{"type":"text","text":" callers waiting on the cancelled task receive a "},{"type":"codeVoice","code":"CancellationError"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Data-Source-Lifec