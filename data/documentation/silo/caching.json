{"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"inlineContent":[{"type":"text","text":"By default every "},{"type":"codeVoice","code":"refresh()"},{"type":"text","text":" call triggers a fetch. Adding a time-to-live (TTL) window changes this: once data is successfully fetched, "},{"type":"codeVoice","code":"refresh()"},{"type":"text","text":" returns the cached value immediately — without touching the network — until the window expires."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"TTL is the primary tool for reducing server load and improving perceived performance. The right TTL value depends entirely on how quickly your data changes and how stale data you can tolerate."}],"type":"paragraph"},{"anchor":"Configuring-TTL","text":"Configuring TTL","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Chain "},{"type":"codeVoice","code":".ttl(_:)"},{"type":"text","text":" on the builder before calling "},{"type":"codeVoice","code":".build()"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["let catalogSource = dataSource {","    try await api.fetchProducts()","} onError: { _ in .keep }",".ttl(.seconds(300)) \/\/ Data stays fresh for 5 minutes",".build()"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"After a successful fetch, calling ","type":"text"},{"code":"refresh()","type":"codeVoice"},{"type":"text","text":" within 5 minutes returns the cached product list without a network call. Calling "},{"type":"codeVoice","code":"refresh()"},{"type":"text","text":" after 5 minutes triggers a new fetch and resets the TTL window."}],"type":"paragraph"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Silo uses ","type":"text"},{"code":"Foundation.Duration","type":"codeVoice"},{"text":", not ","type":"text"},{"code":"Swift.Duration","type":"codeVoice"},{"type":"text","text":". Both use identical literal syntax ("},{"type":"codeVoice","code":".seconds(n)"},{"type":"text","text":", "},{"type":"codeVoice","code":".milliseconds(n)"},{"type":"text","text":"), but they are different types. Always "},{"type":"codeVoice","code":"import Foundation"},{"type":"text","text":" alongside "},{"type":"codeVoice","code":"import Silo"},{"type":"text","text":"."}]}],"style":"note","type":"aside"},{"type":"heading","anchor":"Choosing-a-TTL-Value","text":"Choosing a TTL Value","level":2},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Data type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Suggested TTL"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Rationale","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"User profile, settings","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"5–15 minutes"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Changes infrequently; stale data is low risk","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"News feed, product catalog","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1–5 minutes","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Moderate change rate; some staleness acceptable","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Prices, availability","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"15–60 seconds"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Changes often; stale data has real cost"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Auth tokens, session info"}]}],[{"inlineContent":[{"text":"60–300 seconds","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Sensitive; don’t hold longer than necessary"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Real-time data (stock prices, scores)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No TTL + autoRefresh"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Cache adds latency you don’t want"}]}]]],"header":"row"},{"type":"heading","anchor":"Auto-Clearing-on-Expiry","text":"Auto-Clearing on Expiry","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default when the TTL fires, the cache remains in memory and the data source simply becomes eligible for a re-fetch on the next "},{"type":"codeVoice","code":"refresh()"},{"type":"text","text":" call — no subscriber is notified."}]},{"type":"paragraph","inlineContent":[{"text":"Pass ","type":"text"},{"code":"clear: true","type":"codeVoice"},{"text":" to instead emit the empty value when the TTL fires:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let sessionSource = dataSource {","    try await api.validateSession()","} onError: { _ in .clear }",".ttl(.seconds(900), clear: true) \/\/ Emit empty value after 15 minutes",".build()"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"clear: true"},{"text":" when","type":"text"}]},{"text":" stale data would be misleading or harmful:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Auth tokens \/ session state","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Time-sensitive pricing","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Data that becomes invalid rather than just outdated","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"inlineContent":[{"text":"Use the default (","type":"text"},{"code":"clear: false","type":"codeVoice"},{"text":") when","type":"text"}],"type":"strong"},{"type":"text","text":" showing stale data is acceptable:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"News articles, product descriptions"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"User profiles"}]}]},{"content":[{"inlineContent":[{"text":"Historical statistics","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","anchor":"Timer-Tolerance","text":"Timer Tolerance","level":2},{"inlineContent":[{"text":"Allow the TTL timer to fire slightly later than requested. The OS can then coalesce wake-ups from multiple timers into a single CPU wake-up, improving battery life:","type":"text"}],"type":"paragraph"},{"code":[".ttl(.seconds(300), tolerance: .seconds(15))","\/\/ Fires anywhere between 300 and 315 seconds after the last fetch"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This maps to the "},{"type":"codeVoice","code":"tolerance"},{"text":" parameter of ","type":"text"},{"code":"Task.sleep(for:tolerance:)","type":"codeVoice"},{"text":". On macOS\/iOS, the system decides the exact firing time within the range. Use a tolerance of 5–10% of the TTL duration as a starting point.","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Bypassing-the-Cache","text":"Bypassing the Cache","level":2},{"type":"paragraph","inlineContent":[{"text":"Call ","type":"text"},{"code":"refresh(clear: true)","type":"codeVoice"},{"text":" to force a fresh fetch regardless of the TTL window:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Pull-to-refresh: always fetch fresh","try await catalogSource.refresh(clear: true)"]},{"inlineContent":[{"text":"This clears the cached value, emits the empty value, then performs a full fetch. Any active TTL timer is cancelled and restarted after the new fetch completes.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"TTL and Concurrent Fetches","anchor":"TTL-and-Concurrent-Fetches"},{"type":"paragraph","inlineContent":[{"text":"If two callers both call ","type":"text"},{"type":"codeVoice","code":"refresh()"},{"type":"text","text":" simultaneously when the TTL has expired, only one network request is made — both callers await the same in-flight task. The TTL window is started after that shared task completes."}]},{"type":"heading","anchor":"TTL-Auto-Refresh-and-Caching-Together","text":"TTL, Auto-Refresh, and Caching Together","level":2},{"inlineContent":[{"text":"A common pattern is to configure auto-refresh at a shorter interval than the TTL, so the background timer only actually fetches when the cache has expired:","type":"text"}],"type":"paragraph"},{"code":["let feedSource = dataSource {","    try await api.fetchFeed()","} onError: { _ in .keep }",".ttl(.seconds(120))          \/\/ Cache valid for 2 minutes",".autoRefresh(.seconds(60))   \/\/ Timer fires every minute, but...",".build()                      \/\/ ...first fire is a no-op (still within TTL)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"In this configuration, the effective refresh rate is once per 2 minutes (governed by the TTL), with the auto-refresh timer acting as a “check-in” mechanism that wakes up the data source regularly.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Combining-TTL-with-Retry","text":"Combining TTL with Retry","type":"heading"},{"inlineContent":[{"type":"text","text":"TTL and retry operate at different layers. TTL determines "},{"type":"emphasis","inlineContent":[{"text":"whether","type":"text"}]},{"type":"text","text":" to fetch; retry determines what to do "},{"type":"emphasis","inlineContent":[{"text":"after","type":"text"}]},{"type":"text","text":" a fetch attempt fails:"}],"type":"paragraph"},{"syntax":"swift","code":["let profileSource = dataSource {","    try await api.fetchProfile()","} onError: { _ in .keep }",".ttl(.seconds(300))",".retry(count: 3, delay: .seconds(2)) \/\/ Retry failed fetches up to 3 times",".build()"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If a fetch fails all retry attempts, the cached value is preserved (because "},{"type":"codeVoice","code":"onError"},{"type":"text","text":" returns "},{"type":"codeVoice","code":".keep"},{"type":"text","text":") and the TTL timer is "},{"type":"emphasis","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" reset — the next "},{"type":"codeVoice","code":"refresh()"},{"type":"text","text":" call will trigger another attempt immediately."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/Silo\/documentation\/Silo"]]},"abstract":[{"text":"Prevent redundant network calls by keeping fetched data valid for a configurable duration.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","metadata":{"title":"Caching with TTL","modules":[{"name":"Silo"}],"role":"article","roleHeading":"Article"},"variants":[{"paths":["\/documentation\/silo\/caching"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"url":"doc:\/\/Silo\/documentation\/Silo\/Caching","interfaceLanguage":"swift"},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/Silo\/documentation\/Silo\/TimeControls","doc:\/\/Silo\/documentation\/Silo\/ErrorHandling","doc:\/\/Silo\/documentation\/Silo\/DataSource\/refresh(clear:)","doc:\/\/Silo\/documentation\/Silo\/DataSource\/clear()"],"anchor":"Related-Documentation"},{"title":"Guides","generated":true,"identifiers":["doc:\/\/Silo\/documentation\/Silo\/ErrorHandling","doc:\/\/Silo\/documentation\/Silo\/TimeControls","doc:\/\/Silo\/documentation\/Silo\/Dependencies","doc:\/\/Silo\/documentation\/Silo\/Prerequisites"],"anchor":"Guides"}],"references":{"doc://Silo/documentation/Silo/ErrorHandling":{"type":"topic","abstract":[{"text":"Decide what happens to cached data on failure, and configure automatic retry with backoff strategies.","type":"text"}],"role":"article","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/ErrorHandling","title":"Error Handling and Retry","url":"\/documentation\/silo\/errorhandling"},"doc://Silo/documentation/Silo/Dependencies":{"url":"\/documentation\/silo\/dependencies","type":"topic","abstract":[{"text":"Automatically re-fetch data whenever upstream async stream values change.","type":"text"}],"title":"Dependencies and Reactive Fetching","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/Dependencies","role":"article"},"doc://Silo/documentation/Silo/DataSource/refresh(clear:)":{"url":"\/documentation\/silo\/datasource\/refresh(clear:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"refresh"},{"kind":"text","text":"("},{"kind":"externalParam","text":"clear"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Value"}],"title":"refresh(clear:)","abstract":[{"type":"text","text":"Fetches new data, updating the cache and notifying all stream subscribers on success."}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/refresh(clear:)","type":"topic","role":"symbol"},"doc://Silo/documentation/Silo/DataSource/clear()":{"type":"topic","abstract":[{"text":"Resets the data source to its empty state.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"clear"},{"kind":"text","text":"()"}],"title":"clear()","url":"\/documentation\/silo\/datasource\/clear()","identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/clear()"},"doc://Silo/documentation/Silo":{"type":"topic","abstract":[{"type":"text","text":"Reactive async data management for Swift 6 — fetch, cache, and stream data with zero dependencies."}],"role":"collection","kind":"symbol","identifier":"doc:\/\/Silo\/documentation\/Silo","title":"Silo","url":"\/documentation\/silo"},"doc://Silo/documentation/Silo/TimeControls":{"type":"topic","abstract":[{"type":"text","text":"Limit fetch frequency with throttling, smooth out bursts with debouncing, and keep data current with auto-refresh."}],"role":"article","kind":"article","url":"\/documentation\/silo\/timecontrols","identifier":"doc:\/\/Silo\/documentation\/Silo\/TimeControls","title":"Time Controls"},"doc://Silo/documentation/Silo/Prerequisites":{"type":"topic","abstract":[{"type":"text","text":"Gate fetches on runtime conditions such as network availability or user authentication state."}],"role":"article","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/Prerequisites","title":"Prerequisites and Conditional Fetching","url":"\/documentation\/silo\/prerequisites"}}}