{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Silo provides three complementary time-based policies. Each addresses a different problem:","type":"text"}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Policy"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Problem it solves"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Applied at"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Throttle"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Prevents too many fetches in a short window"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Per fetch call"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Debounce"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Waits for rapid calls to settle before fetching"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Per fetch call"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Auto-refresh"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Keeps data current without manual triggers"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Background"}],"type":"paragraph"}]]]},{"inlineContent":[{"text":"All three can be combined with TTL caching — if cached data is still fresh, neither throttle nor auto-refresh will trigger an actual network call.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Throttle","anchor":"Throttle"},{"inlineContent":[{"text":"Throttling enforces a minimum time between fetches. This is the right tool when a fetch can be triggered by rapid user interaction (button taps, scroll-driven prefetching) and you want a hard rate limit regardless of how many calls arrive.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let refreshSource = dataSource {","    try await api.fetchUpdates()","} onError: { _ in .keep }",".throttle(.seconds(2)) \/\/ At most one fetch per 2 seconds",".build()"]},{"level":3,"type":"heading","text":"Drop vs. Queue Mode","anchor":"Drop-vs-Queue-Mode"},{"inlineContent":[{"text":"Two behaviours are available, selected with the ","type":"text"},{"code":"last","type":"codeVoice"},{"text":" parameter:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Drop mode"}],"type":"strong"},{"text":" (","type":"text"},{"code":"last: false","type":"codeVoice"},{"text":", the default): the first call in a window fetches immediately. Subsequent calls during the window return the cached value without fetching. The pending calls are silently discarded when the window ends.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":[".throttle(.seconds(2))         \/\/ First call goes through; others return cache"]},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Queue mode"}],"type":"strong"},{"text":" (","type":"text"},{"code":"last: true","type":"codeVoice"},{"text":"): the first call fetches. Additional calls during the window are deferred. When the window expires, the ","type":"text"},{"inlineContent":[{"type":"text","text":"most recent"}],"type":"emphasis"},{"text":" queued call is executed.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":[".throttle(.seconds(2), last: true) \/\/ Last caller always gets fresh data eventually"]},{"inlineContent":[{"inlineContent":[{"type":"text","text":"When to choose:"}],"type":"strong"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Drop ("},{"type":"codeVoice","code":"last: false"},{"type":"text","text":")"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Queue ("},{"type":"codeVoice","code":"last: true"},{"type":"text","text":")"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Manual refresh button"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✓ First tap always works"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Search-as-you-type"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✓ Last query always resolves"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Sensor polling"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✓ Discard intermediate readings"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Form auto-save"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"✓ Latest input always saves"}],"type":"paragraph"}]]]},{"level":3,"type":"heading","text":"Throttle Tolerance","anchor":"Throttle-Tolerance"},{"inlineContent":[{"text":"Allow the wait timer in queue mode to fire slightly late:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":[".throttle(.seconds(2), last: true, tolerance: .milliseconds(200))"]},{"level":2,"type":"heading","text":"Debounce","anchor":"Debounce"},{"inlineContent":[{"text":"Debouncing delays execution until calls have stopped arriving for a specified quiet period. Each ","type":"text"},{"code":"refresh()","type":"codeVoice"},{"text":" call resets the timer. Only after the full quiet period elapses does the actual fetch happen.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let searchSource = dataSource { query in","    try await api.search(query: query)","} onError: { _ in .keep }","emptyValue: { [] }",".debounce(.milliseconds(350)) \/\/ Wait 350ms of silence before fetching",".build()"]},{"inlineContent":[{"text":"If ","type":"text"},{"code":"refresh()","type":"codeVoice"},{"text":" is called three times in 200ms, the first two calls are cancelled and only the third one — after 350ms of silence — triggers a fetch.","type":"text"}],"type":"paragraph"},{"style":"tip","content":[{"inlineContent":[{"type":"text","text":"250–400ms is a sweet spot for search debouncing. Values under 150ms feel laggy; values over 500ms feel slow."}],"type":"paragraph"}],"type":"aside","name":"Tip"},{"level":3,"type":"heading","text":"Debounce vs. Throttle Decision Guide","anchor":"Debounce-vs-Throttle-Decision-Guide"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Situation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Use"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Search-as-you-type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Debounce — wait for the user to pause"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Refresh button taps"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Throttle — first tap always works"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Rapid scroll triggers"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Throttle — drop intermediate positions"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Text field auto-complete"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Debounce — only query after typing stops"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Pull-to-refresh gesture"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Neither — call "},{"type":"codeVoice","code":"refresh(clear: true)"},{"type":"text","text":" directly"}],"type":"paragraph"}]]]},{"level":3,"type":"heading","text":"Debounce and Cancellation","anchor":"Debounce-and-Cancellation"},{"inlineContent":[{"text":"Callers that are cancelled by a subsequent ","type":"text"},{"code":"refresh()","type":"codeVoice"},{"text":" call during the debounce window receive a ","type":"text"},{"code":"CancellationError","type":"codeVoice"},{"text":". Handle this if needed:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["do {","    try await searchSource.refresh()","} catch is CancellationError {","    \/\/ Expected — this call was superseded by a newer one","} catch {","    showError(error)","}"]},{"level":2,"type":"heading","text":"Auto-Refresh","anchor":"Auto-Refresh"},{"inlineContent":[{"text":"Auto-refresh periodically calls ","type":"text"},{"code":"refresh()","type":"codeVoice"},{"text":" at a fixed interval while the data source has at least one active subscriber to ","type":"text"},{"code":"values","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"valueWithState","type":"codeVoice"},{"text":". When the first subscriber appears, an immediate refresh is triggered before the first interval elapses — so data is never stale on first observation. The timer stops automatically when the last subscriber terminates.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let stockSource = dataSource {","    try await api.fetchPrice(ticker: \"AAPL\")","} onError: { _ in .keep }",".autoRefresh(.seconds(10)) \/\/ Poll every 10 seconds while being observed",".build()"]},{"syntax":"swift","type":"codeListing","code":["\/\/ Timer starts here:","for await price in stockSource.values {","    priceLabel.text = price.formatted(.currency(code: \"USD\"))","} \/\/ Timer stops here (stream ended)"]},{"inlineContent":[{"text":"This subscriber-driven design means no background work happens when the UI is off-screen.","type":"text"}],"type":"paragraph"},{"style":"important","content":[{"inlineContent":[{"type":"text","text":"Auto-refresh calls "},{"type":"codeVoice","code":"refresh()"},{"type":"text","text":" internally, so all configured policies still apply — TTL, throttle, and debounce all take effect. If data is fresh within its TTL, an auto-refresh call is a no-op that returns the cached value."}],"type":"paragraph"}],"type":"aside","name":"Important"},{"level":3,"type":"heading","text":"Managing Auto-Refresh Manually","anchor":"Managing-Auto-Refresh-Manually"},{"inlineContent":[{"text":"Pause and resume the timer explicitly, for example when the app enters the background:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ AppDelegate \/ SceneDelegate","func sceneDidEnterBackground(_ scene: UIScene) {","    stockSource.stopAutoRefresh()","}","","func sceneWillEnterForeground(_ scene: UIScene) {","    stockSource.resumeAutoRefresh()","}"]},{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/resumeAutoRefresh()","type":"reference"},{"text":" resumes the timer and triggers an immediate refresh, ensuring data is not stale for a full interval after the app returns to the foreground.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To reset the interval from zero (and optionally fire an immediate refresh):","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Reset the 10-second cycle without an immediate fetch","await stockSource.restartAutoRefresh(immediate: false)","","\/\/ Reset and fetch right now (useful when returning from background)","await stockSource.restartAutoRefresh(immediate: true)"]},{"level":3,"type":"heading","text":"Auto-Refresh and Battery","anchor":"Auto-Refresh-and-Battery"},{"inlineContent":[{"text":"Set a tolerance to allow the OS to coalesce wake-ups from multiple timers, reducing CPU wake frequency:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":[".autoRefresh(.seconds(60), tolerance: .seconds(5))","\/\/ Timer fires between 60 and 65 seconds after each refresh"]},{"inlineContent":[{"type":"text","text":"For data that refreshes every minute or more, a 5–10% tolerance has negligible UX impact but measurable battery benefit on mobile devices."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Combining All Three","anchor":"Combining-All-Three"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All three policies can coexist. Evaluation order within a single "},{"type":"codeVoice","code":"refresh()"},{"type":"text","text":" call:"}]},{"type":"codeListing","syntax":null,"code":["1. TTL check  →  2. Debounce wait  →  3. Throttle check  →  4. Fetch"]},{"type":"paragraph","inlineContent":[{"text":"If TTL passes (data is fresh), the cached value is returned immediately and the rest of the pipeline is skipped — no debounce wait, no throttle delay, no fetch.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A complete example for a live sports scoreboard:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let scoreSource = dataSource {","    try await api.fetchLiveScores()","} onError: { _ in .keep }",".debounce(.milliseconds(100))   \/\/ Absorb rapid-fire triggers from events",".ttl(.seconds(5))               \/\/ Don't re-fetch within 5 seconds",".throttle(.seconds(2))          \/\/ Hard rate limit: max 1 fetch per 2 seconds",".autoRefresh(.seconds(15))      \/\/ Background refresh every 15 seconds",".build()"]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Limit fetch frequency with throttling, smooth out bursts with debouncing, and keep data current with auto-refresh."}],"hierarchy":{"paths":[["doc:\/\/Silo\/documentation\/Silo"]]},"kind":"article","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/silo\/timecontrols"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Silo\/documentation\/Silo\/TimeControls"},"metadata":{"role":"article","modules":[{"name":"Silo"}],"title":"Time Controls","roleHeading":"Article"},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/Silo\/documentation\/Silo\/Caching","doc:\/\/Silo\/documentation\/Silo\/DataSource\/stopAutoRefresh()","doc:\/\/Silo\/documentation\/Silo\/DataSource\/resumeAutoRefresh()","doc:\/\/Silo\/documentation\/Silo\/DataSource\/restartAutoRefresh(immediate:)"],"anchor":"Related-Documentation"},{"generated":true,"identifiers":["doc:\/\/Silo\/documentation\/Silo\/Caching","doc:\/\/Silo\/documentation\/Silo\/ErrorHandling","doc:\/\/Silo\/documentation\/Silo\/Dependencies","doc:\/\/Silo\/documentation\/Silo\/Prerequisites"],"anchor":"Guides","title":"Guides"}],"references":{"doc://Silo/documentation/Silo/DataSource/stopAutoRefresh()":{"url":"\/documentation\/silo\/datasource\/stopautorefresh()","type":"topic","abstract":[{"text":"Stop auto-refresh timer.","type":"text"}],"title":"stopAutoRefresh()","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"stopAutoRefresh","kind":"identifier"},{"text":"()","kind":"text"}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/stopAutoRefresh()","role":"symbol"},"doc://Silo/documentation/Silo/DataSource/resumeAutoRefresh()":{"url":"\/documentation\/silo\/datasource\/resumeautorefresh()","type":"topic","abstract":[{"text":"Resume auto-refresh timer.","type":"text"}],"title":"resumeAutoRefresh()","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"resumeAutoRefresh","kind":"identifier"},{"text":"()","kind":"text"}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/resumeAutoRefresh()","role":"symbol"},"doc://Silo/documentation/Silo/Caching":{"url":"\/documentation\/silo\/caching","type":"topic","abstract":[{"type":"text","text":"Prevent redundant network calls by keeping fetched data valid for a configurable duration."}],"title":"Caching with TTL","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/Caching","role":"article"},"doc://Silo/documentation/Silo/Dependencies":{"url":"\/documentation\/silo\/dependencies","type":"topic","abstract":[{"text":"Automatically re-fetch data whenever upstream async stream values change.","type":"text"}],"title":"Dependencies and Reactive Fetching","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/Dependencies","role":"article"},"doc://Silo/documentation/Silo":{"type":"topic","abstract":[{"type":"text","text":"Reactive async data management for Swift 6 — fetch, cache, and stream data with zero dependencies."}],"role":"collection","kind":"symbol","identifier":"doc:\/\/Silo\/documentation\/Silo","title":"Silo","url":"\/documentation\/silo"},"doc://Silo/documentation/Silo/DataSource/restartAutoRefresh(immediate:)":{"url":"\/documentation\/silo\/datasource\/restartautorefresh(immediate:)","type":"topic","abstract":[{"text":"Restart auto-refresh timer.","type":"text"}],"title":"restartAutoRefresh(immediate:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"restartAutoRefresh","kind":"identifier"},{"text":"(","kind":"text"},{"text":"immediate","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":") ","kind":"text"},{"text":"async","kind":"keyword"}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/restartAutoRefresh(immediate:)","role":"symbol"},"doc://Silo/documentation/Silo/Prerequisites":{"type":"topic","abstract":[{"type":"text","text":"Gate fetches on runtime conditions such as network availability or user authentication state."}],"role":"article","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/Prerequisites","title":"Prerequisites and Conditional Fetching","url":"\/documentation\/silo\/prerequisites"},"doc://Silo/documentation/Silo/ErrorHandling":{"type":"topic","abstract":[{"text":"Decide what happens to cached data on failure, and configure automatic retry with backoff strategies.","type":"text"}],"role":"article","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/ErrorHandling","title":"Error Handling and Retry","url":"\/documentation\/silo\/errorhandling"}}}