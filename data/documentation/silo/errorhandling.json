{"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Error handling in Silo is split across two distinct types, each with its own responsibility:"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Used in"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Controls"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Silo\/documentation\/Silo\/FetchErrorAction","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Top-level "},{"type":"codeVoice","code":"onError"},{"type":"text","text":" closure"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Cache contents after all retries are exhausted"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Silo\/documentation\/Silo\/RetryErrorAction","isActive":true}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Per-attempt "},{"type":"codeVoice","code":"onError"},{"type":"text","text":" in "},{"type":"codeVoice","code":".retry()"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Whether to attempt the next retry"}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This separation keeps each handler to one job: the retry "},{"type":"codeVoice","code":"onError"},{"type":"text","text":" decides how hard to fight before giving up; the top-level "},{"type":"codeVoice","code":"onError"},{"type":"text","text":" decides what the user sees after failure. Cache disposition lives in exactly one place."}]},{"level":2,"text":"The Top-Level `onError` Handler","type":"heading","anchor":"The-Top-Level-onError-Handler"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"onError"},{"type":"text","text":" closure on "},{"type":"codeVoice","code":"dataSource()"},{"type":"text","text":" receives the error thrown after all retries are exhausted and returns an "},{"identifier":"doc:\/\/Silo\/documentation\/Silo\/FetchErrorAction","type":"reference","isActive":true},{"type":"text","text":":"}]},{"code":["let profileSource = dataSource {","    try await api.fetchProfile()","} onError: { error in","    switch error {","    case is NetworkOfflineError:","        return .keep   \/\/ Show stale profile while offline","    case is AuthError:","        return .clear  \/\/ Wipe sensitive data on auth failure","    default:","        return .keep","    }","}",".build()"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Silo\/documentation\/Silo\/FetchErrorAction","type":"reference","isActive":true},{"type":"text","text":" has two cases:"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Action"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Cache result"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Use when"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".keep"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Unchanged"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Stale data is better than nothing"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".clear"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Replaced with empty value"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Stale data is wrong or sensitive"}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The error is always re-thrown after the handler runs, so callers can still "},{"type":"codeVoice","code":"catch"},{"type":"text","text":" it:"}]},{"code":["do {","    try await profileSource.refresh()","} catch let error as AuthError {","    showLoginScreen()","} catch {","    showErrorBanner(error.localizedDescription)","}"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"Simple Retry","type":"heading","anchor":"Simple-Retry"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Retry up to N times with a constant delay between attempts:"}]},{"code":["dataSource { ... }","    .retry(count: 3, delay: .seconds(1))","    .build()","\/\/ Attempt 1 → fail → wait 1s → Attempt 2 → fail → wait 1s → Attempt 3 → fail → onError"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"Retry with Per-Attempt Error Gating","type":"heading","anchor":"Retry-with-Per-Attempt-Error-Gating"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Supply a closure returning "},{"identifier":"doc:\/\/Silo\/documentation\/Silo\/RetryErrorAction","type":"reference","isActive":true},{"type":"text","text":" to decide per-error whether to keep retrying:"}]},{"code":["dataSource { ... }","    .retry(count: 3, delay: .seconds(1)) { error in","        switch error {","        case is URLError:       return .retry  \/\/ Network error — try again","        case is DecodingError:  return .stop   \/\/ Parsing error — give up immediately","        default:                return .stop","        }","    }","    .build()"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Silo\/documentation\/Silo\/RetryErrorAction","isActive":true},{"type":"text","text":" has two cases:"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Action","type":"text"}]}],[{"inlineContent":[{"text":"Effect","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Use when","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"code":".retry","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Wait the delay, then attempt again"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Error is transient and worth retrying"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":".stop"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Stop retrying; defer cache decision to top-level "},{"type":"codeVoice","code":"onError"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Error is permanent; further retries would waste effort"}],"type":"paragraph"}]]]},{"inlineContent":[{"type":"text","text":"When "},{"code":".stop","type":"codeVoice"},{"text":" is returned, retrying halts immediately and the error flows to the top-level ","type":"text"},{"code":"onError","type":"codeVoice"},{"type":"text","text":" handler, which decides whether to keep or clear the cache."}],"type":"paragraph"},{"level":2,"anchor":"Exponential-Backoff","text":"Exponential Backoff","type":"heading"},{"inlineContent":[{"type":"text","text":"Each retry waits exponentially longer than the previous. This is the right choice for rate-limited APIs or servers under load:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["dataSource { ... }","    .retry(strategy: .exponentialBackoff(","        maxAttempts: 5,","        initialDelay: .seconds(1),","        multiplier: 2.0","    ))","    .build()","\/\/ Delays: 1s → 2s → 4s → 8s → onError"]},{"inlineContent":[{"type":"text","text":"Cap the maximum wait to avoid very long delays:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":[".retry(strategy: .exponentialBackoff(","    maxAttempts: 6,","    initialDelay: .seconds(1),","    multiplier: 2.0,","    maxDelay: .seconds(30)","))","\/\/ Delays: 1s → 2s → 4s → 8s → 16s → 30s (capped) → onError"]},{"type":"heading","anchor":"Linear-Backoff","text":"Linear Backoff","level":2},{"inlineContent":[{"type":"text","text":"Each retry adds a fixed increment to the previous delay:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":[".retry(strategy: .linearBackoff(","    maxAttempts: 4,","    initialDelay: .seconds(2),","    increment: .seconds(3)","))","\/\/ Delays: 2s → 5s → 8s → onError"]},{"level":2,"anchor":"Custom-Retry-Strategy","text":"Custom Retry Strategy","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Build any delay pattern with a ","type":"text"},{"code":"delayCalculator","type":"codeVoice"},{"text":" closure:","type":"text"}]},{"code":["\/\/ Jittered exponential backoff","let jitteredBackoff = RetryStrategy.custom(maxAttempts: 5) { attempt in","    let base = pow(2.0, Double(attempt - 1))","    let jitter = Double.random(in: 0.8...1.2)","    return .seconds(base * jitter)","}","","dataSource { ... }","    .retry(strategy: jitteredBackoff)","    .build()"],"type":"codeListing","syntax":"swift"},{"name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"delayCalculator"},{"type":"text","text":" closure is called with the current attempt number (1-indexed). Attempt 1 is the first retry, after the initial failure."}],"type":"paragraph"}],"type":"aside"},{"level":2,"text":"Combining Strategy and Error Gating","type":"heading","anchor":"Combining-Strategy-and-Error-Gating"},{"code":["dataSource { ... }","    .retry(","        strategy: .exponentialBackoff(maxAttempts: 4, initialDelay: .seconds(1)),","        onError: { error in","            if error is RateLimitError   { return .retry }","            if error is ServerError      { return .retry }","            return .stop  \/\/ Client errors and decoding failures: stop retrying","        }","    )","    .build()"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Retry-Tolerance","text":"Retry Tolerance","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"All retry variants accept a "},{"type":"codeVoice","code":"tolerance"},{"text":" parameter to allow ","type":"text"},{"type":"codeVoice","code":"Task.sleep"},{"text":" to fire slightly late, improving battery efficiency:","type":"text"}]},{"code":[".retry(count: 3, delay: .seconds(5), tolerance: .milliseconds(500))"],"type":"codeListing","syntax":"swift"},{"anchor":"Interaction-Between-the-Two-onError-Handlers","text":"Interaction Between the Two `onError` Handlers","level":2,"type":"heading"},{"code":["fetch() throws","    │","    └── retry onError? ──.retry──► wait delay ──► fetch() [next attempt]","                │                                       │","                │         ◄──── max attempts reached ───┘","                │","                └──.stop ──► stop retrying","                                    │","                                    ▼","                           top-level onError","                           ├── .keep  → preserve cache","                           └── .clear → emit empty value","                                    │","                                    ▼","                           error re-thrown to caller"],"type":"codeListing","syntax":null}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Decide what happens to cached data on failure, and configure automatic retry with backoff strategies.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/Silo\/documentation\/Silo"]]},"kind":"article","sections":[],"variants":[{"paths":["\/documentation\/silo\/errorhandling"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Silo\/documentation\/Silo\/ErrorHandling"},"metadata":{"modules":[{"name":"Silo"}],"roleHeading":"Article","role":"article","title":"Error Handling and Retry"},"seeAlsoSections":[{"anchor":"Related-Documentation","identifiers":["doc:\/\/Silo\/documentation\/Silo\/Caching","doc:\/\/Silo\/documentation\/Silo\/FetchErrorAction","doc:\/\/Silo\/documentation\/Silo\/RetryErrorAction","doc:\/\/Silo\/documentation\/Silo\/RetryStrategy","doc:\/\/Silo\/documentation\/Silo\/DataSource\/refresh(clear:)"],"title":"Related Documentation"},{"generated":true,"identifiers":["doc:\/\/Silo\/documentation\/Silo\/Caching","doc:\/\/Silo\/documentation\/Silo\/TimeControls","doc:\/\/Silo\/documentation\/Silo\/Dependencies","doc:\/\/Silo\/documentation\/Silo\/Prerequisites"],"anchor":"Guides","title":"Guides"}],"references":{"doc://Silo/documentation/Silo/DataSource/refresh(clear:)":{"url":"\/documentation\/silo\/datasource\/refresh(clear:)","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"refresh"},{"kind":"text","text":"("},{"kind":"externalParam","text":"clear"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":") "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","text":"Value"}],"title":"refresh(clear:)","abstract":[{"type":"text","text":"Fetches new data, updating the cache and notifying all stream subscribers on success."}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/refresh(clear:)","type":"topic","role":"symbol"},"doc://Silo/documentation/Silo/Dependencies":{"url":"\/documentation\/silo\/dependencies","type":"topic","abstract":[{"text":"Automatically re-fetch data whenever upstream async stream values change.","type":"text"}],"title":"Dependencies and Reactive Fetching","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/Dependencies","role":"article"},"doc://Silo/documentation/Silo/Prerequisites":{"type":"topic","abstract":[{"type":"text","text":"Gate fetches on runtime conditions such as network availability or user authentication state."}],"role":"article","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/Prerequisites","title":"Prerequisites and Conditional Fetching","url":"\/documentation\/silo\/prerequisites"},"doc://Silo/documentation/Silo/DataSource":{"url":"\/documentation\/silo\/datasource","type":"topic","abstract":[{"text":"Manages asynchronous data fetching, caching, and reactive streaming for a single value type.","type":"text"}],"title":"DataSource","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"DataSource"}],"navigatorTitle":[{"text":"DataSource","kind":"identifier"}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource","role":"symbol"},"doc://Silo/documentation/Silo/Caching":{"url":"\/documentation\/silo\/caching","type":"topic","abstract":[{"type":"text","text":"Prevent redundant network calls by keeping fetched data valid for a configurable duration."}],"title":"Caching with TTL","kind":"article","identifier":"doc:\/\/Silo\/documentation\/Silo\/Caching","role":"article"},"doc://Silo/documentation/Silo/TimeControls":{"type":"topic","abstract":[{"type":"text","text":"Limit fetch frequency with throttling, smooth out bursts with debouncing, and keep data current with auto-refresh."}],"role":"article","kind":"article","url":"\/documentation\/silo\/timecontrols","identifier":"doc:\/\/Silo\/documentation\/Silo\/TimeControls","title":"Time Controls"},"doc://Silo/documentation/Silo/RetryStrategy":{"type":"topic","abstract":[{"text":"Defines how many times to retry a failed fetch and how long to wait between attempts.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RetryStrategy","kind":"identifier"}],"navigatorTitle":[{"text":"RetryStrategy","kind":"identifier"}],"url":"\/documentation\/silo\/retrystrategy","identifier":"doc:\/\/Silo\/documentation\/Silo\/RetryStrategy","title":"RetryStrategy"},"doc://Silo/documentation/Silo":{"type":"topic","abstract":[{"type":"text","text":"Reactive async data management for Swift 6 — fetch, cache, and stream data with zero dependencies."}],"role":"collection","kind":"symbol","identifier":"doc:\/\/Silo\/documentation\/Silo","title":"Silo","url":"\/documentation\/silo"},"doc://Silo/documentation/Silo/RetryErrorAction":{"type":"topic","abstract":[{"text":"The action a ","type":"text"},{"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource","isActive":true,"type":"reference"},{"text":" should take after an individual retry attempt fails.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"RetryErrorAction"}],"navigatorTitle":[{"kind":"identifier","text":"RetryErrorAction"}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/RetryErrorAction","title":"RetryErrorAction","url":"\/documentation\/silo\/retryerroraction"},"doc://Silo/documentation/Silo/FetchErrorAction":{"url":"\/documentation\/silo\/fetcherroraction","type":"topic","abstract":[{"type":"text","text":"The action a "},{"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource","type":"reference","isActive":true},{"type":"text","text":" should take on a fetch error."}],"title":"FetchErrorAction","kind":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"text":"FetchErrorAction","kind":"identifier"}],"navigatorTitle":[{"text":"FetchErrorAction","kind":"identifier"}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/FetchErrorAction","role":"symbol"}}}