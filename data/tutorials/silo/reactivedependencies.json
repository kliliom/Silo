 focused on Silo, with no boilerplate distractions.","type":"text"}],"role":"pseudoSymbol","kind":"section","url":"\/tutorials\/silo\/buildingad6diceroller#Building-the-Dice-View","identifier":"doc:\/\/Silo\/tutorials\/Silo\/BuildingAD6DiceRoller#Building-the-Dice-View","title":"Building the Dice View"},"DiceService-02.swift":{"type":"file","fileType":"swift","fileName":"DiceService.swift","syntax":"swift","content":["import Silo","","@MainActor","class DiceService {","    let rolls: DataSource<[Int]>","","    init(sides: AsyncStream<Int>) {","        \/\/ Re-roll whenever the number of sides changes","        rolls = dataSource(sides.dependency(.eager)) { sides in","            [Int.random(in: 1...sides)]","        } onError: { _ in","            .keep","        }","        .build()","    }","}"],"highlights":[{"line":7},{"line":8},{"line":9},{"line":10}],"identifier":"DiceService-02.swift"},"doc://Silo/tutorials/Silo/Reactive-Dependencies":{"url":"\/tutorials\/silo\/reactive-dependencies","type":"topic","abstract":[],"title":"Reactive Dependencies","kind":"article","identifier":"doc:\/\/Silo\/tutorials\/Silo\/Reactive-Dependencies","role":"article"},"doc://Silo/tutorials/Silo/ReactiveDependencies#Building-the-Roll-View":{"url":"\/tutorials\/silo\/reactivedependencies#Building-the-Roll-View","type":"section","abstract":[{"text":"Build a configurable dice roller that automatically re-rolls whenever the player changes the dice type or count. You will learn how to declare dependencies, choose the right refresh policy, and wire SwiftUI pickers to reactive streams — resulting in a fully functional application.","type":"text"}],"title":"Building the Roll View","kind":"section","identifier":"doc:\/\/Silo\/tutorials\/Silo\/ReactiveDependencies#Building-the-Roll-View","role":"pseudoSymbol"},"doc://Silo/tutorials/Silo/BuildingAD6DiceRoller#Rolling-Automatically":{"url":"\/tutorials\/silo\/buildingad6diceroller#Rolling-Automatically","type":"section","abstract":[{"type":"text