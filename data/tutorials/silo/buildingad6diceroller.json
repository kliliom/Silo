ext":"DataSourceValueWithState","kind":"typeIdentifier","preciseIdentifier":"s:4Silo24DataSourceValueWithStateV"},{"text":"<","kind":"text"},{"text":"Value","kind":"typeIdentifier"},{"text":">>","kind":"text"}],"identifier":"doc:\/\/Silo\/documentation\/Silo\/DataSource\/valueWithState","role":"symbol"},"doc://Silo/tutorials/Silo/ReactiveDependencies#Setting-Up-the-Dice-Service":{"type":"section","abstract":[{"type":"text","text":"Build a configurable dice roller that automatically re-rolls whenever the player changes the dice type or count. You will learn how to declare dependencies, choose the right refresh policy, and wire SwiftUI pickers to reactive streams — resulting in a fully functional application."}],"role":"pseudoSymbol","kind":"section","identifier":"doc:\/\/Silo\/tutorials\/Silo\/ReactiveDependencies#Setting-Up-the-Dice-Service","url":"\/tutorials\/silo\/reactivedependencies#Setting-Up-the-Dice-Service","title":"Setting Up the Dice Service"},"DiceView-01.png":{"variants":[{"url":"\/images\/Silo\/DiceView-01.png","traits":["1x","light"]}],"alt":"Placeholder view showing the text 'Dice Roller'","type":"image","identifier":"DiceView-01.png"},"DiceView-03.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/Silo\/DiceView-03.png"}],"alt":"Dice view showing a roll result with a Roll button below","type":"image","identifier":"DiceView-03.png"},"doc://Silo/tutorials/Silo/ReactiveDependencies#Bridging-Streams-to-SwiftUI":{"type":"section","abstract":[{"text":"Build a configurable dice roller that automatically re-rolls whenever the player changes the dice type or count. You will learn how to declare dependencies, choose the right refresh policy, and wire SwiftUI pickers to reactive streams — resulting in a fully functional application.","type":"text"}],"role":"pseudoSymbol","kind":"section","title":"Bridging Streams to SwiftUI","url":"\/tutorials\/silo\/reactivedependencies#Bridging-Streams-to-SwiftUI","identifier":"doc:\/\/Silo\/tutorials\/Silo\/ReactiveDependencies#Bridging-Streams-to-SwiftUI"},"doc://Silo/tutorials/Silo/ReactiveDependencies#Adding-a-Second-Dependency":{"type":"section","abstract":[{"text":"Build a configurable dice roller that automatically re-rolls whenever the player changes the dice type or count. You will learn how to declare dependencies, choose the right refresh policy, and wire SwiftUI pickers to reactive streams — resulting in a fully functional application.","type":"text"}],"role":"pseudoSymbol","kind":"section","identifier":"doc:\/\/Silo\/tutorials\/Silo\/ReactiveDependencies#Adding-a-Second-Dependency","url":"\/tutorials\/silo\/reactivedependencies#Adding-a-Second-Dependency","title":"Adding a Second Dependency"},"doc://Silo/tutorials/Silo/BuildingAD6DiceRoller#Creating-the-Data-Source":{"type":"section","abstract":[{"text":"In this tutorial, you will build a D6 dice roller using Silo. The fetch is a single line — ","type":"text"},{"code":"Int.random(in: 1...6)","type":"codeVoice"},{"text":" — so every concept you encounter is focused on Silo, with no boilerplate distractions.","type":"text"}],"role":"pseudoSymbol","kind":"section","url":"\/tutorials\/silo\/buildingad6diceroller#Creating-the-Data-Source","identifier":"doc:\/\/Silo\/tutorials\/Silo\/BuildingAD6DiceRoller#Creating-the-Data-Source","title":"Creating the Data Source"},"DiceRoller-01.swift":{"type":"file","fileType":"swift","fileName":"DiceRoller.swift","syntax":"swift","content":["import Silo","","@MainActor","class DiceRoller {","    static let shared = DiceRoller()","","    private init() {}","}"],"highlights":[],"identifier":"DiceRoller-01.swift"},"doc://Silo/tutorials/Silo":{"type":"topic","abstract":[{"type":"text","text":"These two hands-on tutorials take you from a basic data source to a fully reactive, dependency-driven data layer. By the end, you will know how to handle caching, retry, auto-refresh, and upstream state changes in real SwiftUI apps."}],"role":"overview","kind":"overview","url":"\/tutorials\/silo","